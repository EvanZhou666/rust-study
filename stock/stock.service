[Unit]
Description=Stock Commodity Price Monitor
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=stock
Group=stock

# 将 /path/to/stock 替换为实际部署路径
WorkingDirectory=/home/stock
ExecStart=/home/stock/stock

# 自动重启
Restart=on-failure
RestartSec=10

# 日志配置
StandardOutput=journal
StandardError=journal

# 安全限制
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/home/stock/data

[Install]
WantedBy=multi-user.target
